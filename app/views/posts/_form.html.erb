<%= form_with model: post, class: "space-y-4" do |f| %>
  <div>
    <%= f.label :title, class: "block text-sm font-medium" %>
    <%= f.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
  </div>
  <div>
    <%= f.label :content, class: "block text-sm font-medium" %>
    <%= f.rich_text_area :content %>
  </div>
  <div class="flex items-center gap-3">
    <%= f.submit class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500" %>
    <%= link_to "Cancel", posts_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
