<%= render "shared/content_page" do %>
  <article class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
    <h1 class="text-2xl font-bold mb-4"><%= display_post_title(@post) %></h1>
    <div class="lexxy-content prose prose-gray max-w-none">
      <%= @post.content %>
    </div>
  </article>
  <div class="mt-4 flex gap-3">
    <%= link_to "Edit", edit_post_path(@post), class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500" %>
    <%= button_to "Delete", @post, method: :delete, class: "rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-500", data: { turbo_confirm: "Are you sure?" } %>
  </div>
<% end %>
