<div class="border border-gray-200 rounded-lg p-4">
  <div class="flex items-center justify-between">
    <h3 class="font-medium"><%= link_to display_post_title(post), post, class: "text-blue-600 hover:underline" %></h3>
    <div class="flex gap-2 text-xs">
      <%= link_to "Show", post, class: "text-gray-500 hover:text-gray-700" %>
      <%= link_to "Edit", edit_post_path(post), class: "text-gray-500 hover:text-gray-700" %>
      <%= button_to "Delete", post, method: :delete, class: "text-red-500 hover:text-red-700", data: { turbo_confirm: "Are you sure?" } %>
    </div>
  </div>
  <div class="mt-2 text-sm text-gray-600 line-clamp-2 lexxy-content">
    <%= post.content %>
  </div>
</div>
