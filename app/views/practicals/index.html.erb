<div class="w-full max-w-4xl mx-auto space-y-12 pb-20">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">実務ユースケース</h1>
      <p class="mt-2 text-gray-500">Lexxy を実際のプロダクトで使う場合のパターン集（10 パターン）</p>
    </div>
    <%= link_to "← 機能一覧に戻る", root_path, class: "text-sm text-blue-600 hover:underline shrink-0" %>
  </div>

  <%# ==================== 1. Blog Article ==================== %>
  <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
  <%= render "section_header",
      title:       "1. ブログ記事エディタ",
      description: "CMS のような本格的な記事編集。コードブロック・画像添付・見出しを活用。",
      badge:       "基本 + コード + 添付",
      badge_class: "bg-blue-50 text-blue-600" %>

    <%= form_with url: practicals_path, method: :get, local: true, data: { turbo: false }, class: "space-y-4" do |f| %>
      <%= hidden_field_tag :submitted, "blog" %>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="md:col-span-2">
          <%= label_tag :blog_title, "記事タイトル", class: "block text-sm font-medium mb-1" %>
          <%= text_field_tag :blog_title, params[:blog_title], placeholder: "例: Rails 8 の新機能について", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
        <div>
          <%= label_tag :blog_category, "カテゴリ", class: "block text-sm font-medium mb-1" %>
          <%= select_tag :blog_category, options_for_select(["技術", "デザイン", "ビジネス", "カルチャー"], params[:blog_category]), prompt: "選択してください", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
      </div>

      <div>
        <%= label_tag :blog_meta, "SEO メタディスクリプション", class: "block text-sm font-medium mb-1" %>
        <%= text_area_tag :blog_meta, params[:blog_meta], rows: 2, placeholder: "検索結果に表示される説明文", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
      </div>

      <div>
        <%= label_tag :blog_content, "記事本文", class: "block text-sm font-medium mb-1" %>
        <lexxy-editor name="blog_content" class="lexxy-content" placeholder="記事の内容を書き始めてください..."><%= params[:blog_content].presence %></lexxy-editor>
      </div>

      <div class="flex items-center gap-4 pt-2">
        <div class="flex items-center gap-2">
          <%= check_box_tag :blog_published, "1", params[:blog_published].present?, class: "rounded border-gray-300" %>
          <%= label_tag :blog_published, "公開する", class: "text-sm" %>
        </div>
        <%= f.submit "プレビュー", class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500" %>
      </div>
    <% end %>

    <% if @submitted && @submitted[:submitted] == "blog" %>
      <%# Preview rendering removed for brevity - handled in a real app by a show action %>
    <% end %>
  </section>

  <%# ==================== 2. Announcement with @mentions ==================== %>
  <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
  <%= render "section_header",
      title:       "2. 社内お知らせ + @メンション",
      description: "チームメンバーを @mention でメンションし、関連資料を添付。",
      badge:       "メンション + 添付",
      badge_class: "bg-green-50 text-green-600" %>

    <%= form_with url: practicals_path, method: :get, local: true, data: { turbo: false }, class: "space-y-4" do |f| %>
      <%= hidden_field_tag :submitted, "announcement" %>

      <div>
        <%= label_tag :announcement_title, "タイトル", class: "block text-sm font-medium mb-1" %>
        <%= text_field_tag :announcement_title, params[:announcement_title], placeholder: "例: 来週の全体ミーティングのお知らせ", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= label_tag :announcement_audience, "対象", class: "block text-sm font-medium mb-1" %>
          <%= select_tag :announcement_audience, options_for_select(["全社員", "開発チーム", "デザインチーム", "マーケティング"], params[:announcement_audience]), prompt: "選択してください", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
        <div>
          <%= label_tag :announcement_priority, "重要度", class: "block text-sm font-medium mb-1" %>
          <%= select_tag :announcement_priority, options_for_select([["通常", "normal"], ["重要", "important"], ["緊急", "urgent"]], params[:announcement_priority]), class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
      </div>

      <div>
        <%= label_tag :announcement_body, "本文", class: "block text-sm font-medium mb-1" %>
        <lexxy-editor name="announcement_body" class="lexxy-content" placeholder="@" でチームメンバーをメンションできます...">
          <lexxy-prompt trigger="@" src="<%= people_path %>" name="mention"></lexxy-prompt>
        </lexxy-editor>
      </div>

      <div class="text-xs text-gray-400">
        💡 <code>@</code> を入力すると登録済みのメンバーが候補に表示されます。ファイルをドラッグ＆ドロップして添付することもできます。
      </div>

      <%= f.submit "プレビュー", class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500" %>
    <% end %>
  </section>

  <%# ==================== 3. Support Reply ==================== %>
  <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
  <%= render "section_header",
      title:       "3. カスタマーサポート返信",
      description: "既存のスレッドを確認しながら、メンション付きで返信を作成。",
      badge:       "既読表示 + メンション",
      badge_class: "bg-amber-50 text-amber-600" %>

    <div class="bg-gray-50 rounded-lg border border-gray-200 p-4 space-y-3">
      <div class="text-xs font-medium text-gray-400 uppercase tracking-wide">返信元チケット</div>
      <div class="border-l-4 border-blue-400 pl-4 space-y-2">
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium">山田 太郎</span>
          <span class="text-xs text-gray-400">&lt;yamada@example.com&gt;</span>
          <span class="text-xs text-gray-400">2026/06/12 14:32</span>
        </div>
        <div class="text-sm text-gray-700 lexxy-content">
          <p>ログインボタンをクリックしても何も反応しません。ブラウザは Chrome 最新版です。</p>
          <p>エラーメッセージなどは表示されていません。</p>
        </div>
        <div class="text-xs text-gray-400">チケット #TKT-2024-0312</div>
      </div>
    </div>

    <%= form_with url: practicals_path, method: :get, local: true, data: { turbo: false }, class: "space-y-4 pt-2" do |f| %>
      <%= hidden_field_tag :submitted, "support" %>

      <div>
        <div class="flex items-center justify-between mb-1">
          <%= label_tag :support_reply, "返信", class: "block text-sm font-medium" %>
          <span class="text-xs text-gray-400">@ で担当者をメンション / ファイル添付可</span>
        </div>
        <lexxy-editor name="support_reply" class="lexxy-content" placeholder="返信内容を入力..." permitted-attachment-types="image/png image/jpeg image/gif image/webp application/pdf">
          <lexxy-prompt trigger="@" src="<%= people_path %>" name="mention"></lexxy-prompt>
        </lexxy-editor>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit "返信を送信", class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500" %>
        <span class="text-xs text-gray-400">実際には送信されません（デモ用フォームです）</span>
      </div>
    <% end %>
  </section>

  <%# ==================== 4. Email Template Variables ==================== %>
  <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
  <%= render "section_header",
      title:       "4. メールテンプレート変数挿入",
      description: "カスタムプロンプトでテンプレート変数を挿入。マーケティングメールなどに。",
      badge:       "カスタムプロンプト",
      badge_class: "bg-purple-50 text-purple-600" %>

    <%= form_with url: practicals_path, method: :get, local: true, data: { turbo: false }, class: "space-y-4" do |f| %>
      <%= hidden_field_tag :submitted, "email" %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= label_tag :email_subject, "件名", class: "block text-sm font-medium mb-1" %>
          <%= text_field_tag :email_subject, params[:email_subject], placeholder: "例: {{customer_name}} 様、キャンペーンのお知らせ", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
        <div>
          <%= label_tag :email_recipient, "宛先リスト", class: "block text-sm font-medium mb-1" %>
          <%= text_field_tag :email_recipient, params[:email_recipient], placeholder: "例: customers@example.com", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
      </div>

      <div>
        <%= label_tag :email_body, "本文", class: "block text-sm font-medium mb-1" %>
        <div class="text-xs text-gray-400 mb-2">
          💡 <code>{{</code> と入力すると挿入可能な変数が表示されます
        </div>
        <lexxy-editor name="email_body" class="lexxy-content" placeholder="{{ で変数を挿入...">
          <lexxy-prompt trigger="{{" insert-editable-text>
            <lexxy-prompt-item search="customer_name">
              <template type="menu"><code class="text-purple-600">{{customer_name}}</code></template>
              <template type="editor"><span class="text-purple-600 font-medium bg-purple-50 px-1 rounded">{{customer_name}}</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="company_name">
              <template type="menu"><code class="text-purple-600">{{company_name}}</code></template>
              <template type="editor"><span class="text-purple-600 font-medium bg-purple-50 px-1 rounded">{{company_name}}</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="unsubscribe_link">
              <template type="menu"><code class="text-purple-600">{{unsubscribe_link}}</code></template>
              <template type="editor"><span class="text-purple-600 font-medium bg-purple-50 px-1 rounded">{{unsubscribe_link}}</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="promo_code">
              <template type="menu"><code class="text-purple-600">{{promo_code}}</code></template>
              <template type="editor"><span class="text-purple-600 font-medium bg-purple-50 px-1 rounded">{{promo_code}}</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="expiry_date">
              <template type="menu"><code class="text-purple-600">{{expiry_date}}</code></template>
              <template type="editor"><span class="text-purple-600 font-medium bg-purple-50 px-1 rounded">{{expiry_date}}</span></template>
            </lexxy-prompt-item>
          </lexxy-prompt>
        </lexxy-editor>
      </div>

      <%= f.submit "プレビュー", class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500" %>
    <% end %>
  </section>

  <%# ==================== 5. Quick Task ==================== %>
  <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
  <%= render "section_header",
      title:       "5. 簡易タスク管理",
      description: "単一行のタイトルと最小限のツールバーで素早くタスクを記録。",
      badge:       "単一行 + 最小ツールバー",
      badge_class: "bg-rose-50 text-rose-600" %>

    <%= form_with url: practicals_path, method: :get, local: true, data: { turbo: false }, class: "space-y-4" do |f| %>
      <%= hidden_field_tag :submitted, "task" %>

      <div>
        <%= label_tag :task_title, "タスク", class: "block text-sm font-medium mb-1" %>
        <lexxy-editor name="task_title" class="lexxy-content" placeholder="タスクを入力..." preset="singleline"></lexxy-editor>
      </div>

      <div>
        <%= label_tag :task_description, "詳細（任意）", class: "block text-sm font-medium mb-1" %>
        <lexxy-editor name="task_description" class="lexxy-content" placeholder="補足情報があれば..." preset="minimal"></lexxy-editor>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <%= label_tag :task_due, "期限", class: "block text-sm font-medium mb-1" %>
          <%= date_field_tag :task_due, params[:task_due], class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
        <div>
          <%= label_tag :task_priority, "優先度", class: "block text-sm font-medium mb-1" %>
          <%= select_tag :task_priority, options_for_select([["低", "low"], ["中", "medium"], ["高", "high"], ["最優先", "critical"]], params[:task_priority] || "medium"), class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
        <div>
          <%= label_tag :task_assignee, "担当者", class: "block text-sm font-medium mb-1" %>
          <%= select_tag :task_assignee, options_from_collection_for_select(Person.all, :id, :name, params[:task_assignee]), prompt: "選択してください", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
      </div>

      <%= f.submit "タスクを作成", class: "rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500" %>
    <% end %>
  </section>

  <%# ==================== 6. Incident Report ==================== %>
  <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
    <%= render "section_header",
        title:       "6. インシデントレポート",
        description: "コードブロックでエラーログを貼付、画像添付、文字色で緊急度をハイライト。",
        badge:       "コード + ハイライト + 添付",
        badge_class: "bg-red-50 text-red-600" %>

    <%= form_with url: practicals_path, method: :get, local: true, data: { turbo: false }, class: "space-y-4" do |f| %>
      <%= hidden_field_tag :submitted, "incident" %>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <%= label_tag :incident_id, "インシデント番号", class: "block text-sm font-medium mb-1" %>
          <%= text_field_tag :incident_id, params[:incident_id], placeholder: "例: INC-2026-0612", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
        <div>
          <%= label_tag :incident_severity, "緊急度", class: "block text-sm font-medium mb-1" %>
          <%= select_tag :incident_severity, options_for_select(["P1（最重要）", "P2（重要）", "P3（通常）", "P4（情報）"], params[:incident_severity] || "P3（通常）"), class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
        <div>
          <%= label_tag :incident_status, "ステータス", class: "block text-sm font-medium mb-1" %>
          <%= select_tag :incident_status, options_for_select(["発生中", "調査中", "対応中", "解決済"], params[:incident_status] || "発生中"), class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
      </div>

      <div>
        <%= label_tag :incident_summary, "概要", class: "block text-sm font-medium mb-1" %>
        <lexxy-editor name="incident_summary" class="lexxy-content" placeholder="事象の概要を記載..." preset="singleline"></lexxy-editor>
      </div>

      <div>
        <%= label_tag :incident_details, "詳細・再現手順", class: "block text-sm font-medium mb-1" %>
        <div class="text-xs text-gray-400 mb-2">
          💡 コードブロック（```）でログやエラーメッセージを貼付 / 画像をドラッグ＆ドロップしてスクリーンショットを添付 / 文字色で重要ポイントを目立たせられます
        </div>
        <lexxy-editor name="incident_details" class="lexxy-content" placeholder="再現手順、エラーメッセージ、調査結果を記載..." preset="code">
          <lexxy-prompt trigger="#" insert-editable-text>
            <lexxy-prompt-item search="調査中">
              <template type="menu"><span class="text-amber-600">#調査中</span></template>
              <template type="editor"><span class="text-amber-600 font-medium bg-amber-50 px-1 rounded">#調査中</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="対応完了">
              <template type="menu"><span class="text-green-600">#対応完了</span></template>
              <template type="editor"><span class="text-green-600 font-medium bg-green-50 px-1 rounded">#対応完了</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="要フォローアップ">
              <template type="menu"><span class="text-red-600">#要フォローアップ</span></template>
              <template type="editor"><span class="text-red-600 font-medium bg-red-50 px-1 rounded">#要フォローアップ</span></template>
            </lexxy-prompt-item>
          </lexxy-prompt>
        </lexxy-editor>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit "レポートを保存", class: "rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-500" %>
        <span class="text-xs text-gray-400">実際には保存されません（デモ用フォームです）</span>
      </div>
    <% end %>
  </section>

  <%# ==================== 7. Meeting Minutes ==================== %>
  <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
    <%= render "section_header",
        title:       "7. 議事録エディタ",
        description: "@メンションで出席者を記録、#タグで議題を分類、資料を添付。",
        badge:       "メンション + タグ + 添付",
        badge_class: "bg-teal-50 text-teal-600" %>

    <%= form_with url: practicals_path, method: :get, local: true, data: { turbo: false }, class: "space-y-4" do |f| %>
      <%= hidden_field_tag :submitted, "meeting" %>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="md:col-span-2">
          <%= label_tag :meeting_title, "会議タイトル", class: "block text-sm font-medium mb-1" %>
          <%= text_field_tag :meeting_title, params[:meeting_title], placeholder: "例: 週次開発ミーティング", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
        <div>
          <%= label_tag :meeting_date, "開催日", class: "block text-sm font-medium mb-1" %>
          <%= date_field_tag :meeting_date, params[:meeting_date] || Date.current.to_s, class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
      </div>

      <div>
        <%= label_tag :meeting_attendees, "出席者", class: "block text-sm font-medium mb-1" %>
        <div class="text-xs text-gray-400 mb-2">
          💡 <code>@</code> で出席者をメンションして記録（候補が表示されます）
        </div>
        <lexxy-editor name="meeting_attendees" class="lexxy-content" placeholder="@ で出席者を追加..." preset="minimal">
          <lexxy-prompt trigger="@" src="<%= people_path %>" name="mention"></lexxy-prompt>
        </lexxy-editor>
      </div>

      <div>
        <%= label_tag :meeting_agenda, "議事内容・決定事項", class: "block text-sm font-medium mb-1" %>
        <div class="text-xs text-gray-400 mb-2">
          💡 <code>#</code> でタグ（#議題 #タスク #決定 etc.）を挿入して分類
        </div>
        <lexxy-editor name="meeting_agenda" class="lexxy-content" placeholder="議事内容を記載...">
          <lexxy-prompt trigger="#" insert-editable-text>
            <lexxy-prompt-item search="議題">
              <template type="menu"><span class="text-teal-600">#議題</span></template>
              <template type="editor"><span class="text-teal-600 font-medium bg-teal-50 px-1 rounded">#議題</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="タスク">
              <template type="menu"><span class="text-blue-600">#タスク</span></template>
              <template type="editor"><span class="text-blue-600 font-medium bg-blue-50 px-1 rounded">#タスク</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="決定">
              <template type="menu"><span class="text-green-600">#決定</span></template>
              <template type="editor"><span class="text-green-600 font-medium bg-green-50 px-1 rounded">#決定</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="検討事項">
              <template type="menu"><span class="text-amber-600">#検討事項</span></template>
              <template type="editor"><span class="text-amber-600 font-medium bg-amber-50 px-1 rounded">#検討事項</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="次回">
              <template type="menu"><span class="text-purple-600">#次回</span></template>
              <template type="editor"><span class="text-purple-600 font-medium bg-purple-50 px-1 rounded">#次回</span></template>
            </lexxy-prompt-item>
          </lexxy-prompt>
          <lexxy-prompt trigger="@" src="<%= people_path %>" name="mention"></lexxy-prompt>
        </lexxy-editor>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit "議事録を保存", class: "rounded-md bg-teal-600 px-4 py-2 text-sm font-medium text-white hover:bg-teal-500" %>
        <span class="text-xs text-gray-400">実際には保存されません（デモ用フォームです）</span>
      </div>
    <% end %>
  </section>

  <%# ==================== 8. Knowledge Wiki ==================== %>
  <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
    <%= render "section_header",
        title:       "8. 社内ナレッジ / Wiki 編集",
        description: "コードブロックで手順を共有、画像・動画を添付して視覚的なナレッジベースを構築。",
        badge:       "コード + フル機能",
        badge_class: "bg-indigo-50 text-indigo-600" %>

    <%= form_with url: practicals_path, method: :get, local: true, data: { turbo: false }, class: "space-y-4" do |f| %>
      <%= hidden_field_tag :submitted, "wiki" %>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="md:col-span-2">
          <%= label_tag :wiki_title, "記事タイトル", class: "block text-sm font-medium mb-1" %>
          <%= text_field_tag :wiki_title, params[:wiki_title], placeholder: "例: 開発環境構築手順", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
        <div>
          <%= label_tag :wiki_category, "カテゴリ", class: "block text-sm font-medium mb-1" %>
          <%= select_tag :wiki_category, options_for_select(["開発", "インフラ", "デザイン", "ビジネス", "その他"], params[:wiki_category]), class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
      </div>

      <div>
        <%= label_tag :wiki_body, "本文", class: "block text-sm font-medium mb-1" %>
        <div class="text-xs text-gray-400 mb-2">
          💡 コードブロック（```）でコマンドや設定ファイルを共有 / 画像や動画をドラッグ＆ドロップで添付
        </div>
        <lexxy-editor name="wiki_body" class="lexxy-content" placeholder="ナレッジ記事を書き始めてください..." preset="code">
          <lexxy-prompt trigger="#" insert-editable-text>
            <lexxy-prompt-item search="手順">
              <template type="menu"><span class="text-indigo-600">#手順</span></template>
              <template type="editor"><span class="text-indigo-600 font-medium bg-indigo-50 px-1 rounded">#手順</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="注意">
              <template type="menu"><span class="text-red-600">#注意</span></template>
              <template type="editor"><span class="text-red-600 font-medium bg-red-50 px-1 rounded">#注意</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="Tips">
              <template type="menu"><span class="text-green-600">#Tips</span></template>
              <template type="editor"><span class="text-green-600 font-medium bg-green-50 px-1 rounded">#Tips</span></template>
            </lexxy-prompt-item>
          </lexxy-prompt>
        </lexxy-editor>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit "記事を公開", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
        <span class="text-xs text-gray-400">実際には公開されません（デモ用フォームです）</span>
      </div>
    <% end %>
  </section>

  <%# ==================== 9. Weekly Report ==================== %>
  <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
    <%= render "section_header",
        title:       "9. 週次レポート / 進捗報告",
        description: "テンプレート変数で効率的に週次報告を作成。最小ツールバーでシンプルなUX。",
        badge:       "テンプレート変数 + 最小ツールバー",
        badge_class: "bg-orange-50 text-orange-600" %>

    <%= form_with url: practicals_path, method: :get, local: true, data: { turbo: false }, class: "space-y-4" do |f| %>
      <%= hidden_field_tag :submitted, "weekly" %>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="md:col-span-2">
          <%= label_tag :weekly_period, "報告対象期間", class: "block text-sm font-medium mb-1" %>
          <%= text_field_tag :weekly_period, params[:weekly_period], placeholder: "例: 2026/06/09 〜 2026/06/13", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
        <div>
          <%= label_tag :week, "週", class: "block text-sm font-medium mb-1" %>
          <%= select_tag :week, options_for_select((1..52).map { |w| ["#{w}週目", w] }, params[:week] || Time.current.strftime("%V").to_i), class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-1">
          <%= label_tag :weekly_report, "レポート内容", class: "block text-sm font-medium" %>
          <span class="text-xs text-gray-400"><code>{{</code> でテンプレート変数を挿入</span>
        </div>
        <lexxy-editor name="weekly_report" class="lexxy-content" placeholder="週次レポートを記載..." preset="minimal">
          <lexxy-prompt trigger="{{" insert-editable-text>
            <lexxy-prompt-item search="project_name">
              <template type="menu"><code class="text-orange-600">{{project_name}}</code></template>
              <template type="editor"><span class="text-orange-600 font-medium bg-orange-50 px-1 rounded">{{project_name}}</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="completed_tasks">
              <template type="menu"><code class="text-orange-600">{{completed_tasks}}</code></template>
              <template type="editor"><span class="text-orange-600 font-medium bg-orange-50 px-1 rounded">{{completed_tasks}}</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="next_week_plan">
              <template type="menu"><code class="text-orange-600">{{next_week_plan}}</code></template>
              <template type="editor"><span class="text-orange-600 font-medium bg-orange-50 px-1 rounded">{{next_week_plan}}</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="blockers">
              <template type="menu"><code class="text-orange-600">{{blockers}}</code></template>
              <template type="editor"><span class="text-orange-600 font-medium bg-orange-50 px-1 rounded">{{blockers}}</span></template>
            </lexxy-prompt-item>
            <lexxy-prompt-item search="member_name">
              <template type="menu"><code class="text-orange-600">{{member_name}}</code></template>
              <template type="editor"><span class="text-orange-600 font-medium bg-orange-50 px-1 rounded">{{member_name}}</span></template>
            </lexxy-prompt-item>
          </lexxy-prompt>
        </lexxy-editor>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit "レポートを提出", class: "rounded-md bg-orange-600 px-4 py-2 text-sm font-medium text-white hover:bg-orange-500" %>
        <span class="text-xs text-gray-400">実際には提出されません（デモ用フォームです）</span>
      </div>
    <% end %>
  </section>

  <%# ==================== 10. Kanban Ticket ==================== %>
  <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
    <%= render "section_header",
        title:       "10. カンバン・チケット詳細",
        description: "Markdown 有効で手軽に記述、@メンションで担当者、添付で仕様キャプチャ。",
        badge:       "Markdown + メンション + 添付制限",
        badge_class: "bg-cyan-50 text-cyan-600" %>

    <div class="bg-cyan-50 rounded-lg border border-cyan-100 p-4 flex items-start gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-cyan-600 shrink-0 mt-0.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
      </svg>
      <div class="text-sm text-cyan-800">
        <p class="font-medium">チケット #TKT-2026-015</p>
        <p>ステータス: 開発中 | 優先度: 高 | 担当: 未割り当て</p>
      </div>
    </div>

    <%= form_with url: practicals_path, method: :get, local: true, data: { turbo: false }, class: "space-y-4" do |f| %>
      <%= hidden_field_tag :submitted, "kanban" %>

      <div>
        <%= label_tag :kanban_title, "件名", class: "block text-sm font-medium mb-1" %>
        <lexxy-editor name="kanban_title" class="lexxy-content" placeholder="タスクの件名を入力..." preset="singleline"></lexxy-editor>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= label_tag :kanban_assignee, "担当者", class: "block text-sm font-medium mb-1" %>
          <%= select_tag :kanban_assignee, options_from_collection_for_select(Person.all, :id, :name, params[:kanban_assignee]), prompt: "選択してください", class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
        <div>
          <%= label_tag :kanban_due, "期限", class: "block text-sm font-medium mb-1" %>
          <%= date_field_tag :kanban_due, params[:kanban_due], class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
        </div>
      </div>

      <div>
        <%= label_tag :kanban_description, "詳細", class: "block text-sm font-medium mb-1" %>
        <div class="text-xs text-gray-400 mb-2">
          💡 <code>@</code> で担当者をメンション / 画像のみ添付可（仕様キャプチャ用）
        </div>
        <lexxy-editor name="kanban_description" class="lexxy-content" placeholder="タスクの詳細や仕様を記載..." permitted-attachment-types="image/png image/jpeg image/gif image/webp">
          <lexxy-prompt trigger="@" src="<%= people_path %>" name="mention"></lexxy-prompt>
        </lexxy-editor>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit "チケットを更新", class: "rounded-md bg-cyan-600 px-4 py-2 text-sm font-medium text-white hover:bg-cyan-500" %>
        <span class="text-xs text-gray-400">実際には更新されません（デモ用フォームです）</span>
      </div>
    <% end %>
  </section>

  <%# ==================== Summary ==================== %>
  <section class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl border border-gray-200 p-6 space-y-3">
    <h2 class="text-lg font-semibold">実務適用のポイント</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
      <div class="bg-white rounded-lg p-4 border border-gray-200">
        <div class="font-medium mb-1">ハイライト + タグで見える化</div>
        <p class="text-gray-500">インシデントレポートでは文字色で緊急度を強調し、議事録では <code>#</code> タグで議題を分類することで、業務ドキュメントの可読性を高められます。</p>
      </div>
      <div class="bg-white rounded-lg p-4 border border-gray-200">
        <div class="font-medium mb-1">プリセットの使い分け</div>
        <p class="text-gray-500">タイトル欄には <code>preset="singleline"</code>、補足欄には <code>preset="minimal"</code>、技術文書には <code>preset="code"</code> など、入力内容に応じてツールバーを使い分けることでUXを最適化できます。</p>
      </div>
      <div class="bg-white rounded-lg p-4 border border-gray-200">
        <div class="font-medium mb-1">カスタムプロンプトで業務効率化</div>
        <p class="text-gray-500">メールテンプレートの変数挿入のように、<code>&lt;lexxy-prompt&gt;</code> を使うと業務固有の入力をガイドできます。</p>
      </div>
      <div class="bg-white rounded-lg p-4 border border-gray-200">
        <div class="font-medium mb-1">メンション + ファイル添付の組み合わせ</div>
        <p class="text-gray-500">サポート返信や社内連絡では、メンションとファイル添付を同時に有効にすることで、コミュニケーションを効率化できます。</p>
      </div>
      <div class="bg-white rounded-lg p-4 border border-gray-200">
        <div class="font-medium mb-1">Action Text との互換性</div>
        <p class="text-gray-500">Lexxy は Action Text と同じ canonical HTML 形式を出力するため、既存の <code>has_rich_text</code> モデルをそのまま利用できます。</p>
      </div>
    </div>
  </section>
</div>
